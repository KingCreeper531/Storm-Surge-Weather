# Storm Surge Weather — Environment Variables
# Copy this to .env and fill in your values

# MAPBOX TOKEN (REQUIRED for the map to work)
# 1. Go to https://account.mapbox.com/access-tokens/
# 2. Create a token (or use default public token)
# 3. IMPORTANT: Under "Allowed URLs" add: http://localhost:3001
#    OR leave Allowed URLs completely empty (allows all URLs)
# 4. Paste the token below
MAPBOX_TOKEN=pk.eyJ1Ijoic3Rvcm0tc3VyZ2UiLCJhIjoiY21tb3lsZXg3MDlyeTJwcHoxYjZ4emNudiJ9.de5YAbfQMvSzpVNH8QxmGw

# ANTHROPIC API KEY (optional — for AI assistant)
# Get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Server port (default: 3001)
PORT=3001

# Python radar service port (default: 3002)  
RADAR_PORT=3002
