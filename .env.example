# Core runtime
PORT=3001
NODE_ENV=production
JWT_SECRET=change-me-to-a-long-random-value

# Frontend origin for CORS
FRONTEND_URL=https://your-frontend.example.com

# Mapbox token delivered via /token.js
MAPBOX_TOKEN=

# Weather providers
WEATHERNEXT_KEY=
WEATHERNEXT2_KEY=
TOMORROW_API_KEY=
TOMORROW_RADAR_TILE_TEMPLATE=
DEBUG_RADAR=0
DEBUG_AUTH=0
UPSTREAM_TIMEOUT_MS=9000

# Google Cloud Storage (optional)
GOOGLE_CLOUD_KEY=
GCS_BUCKET=storm_surge_bucket
GCS_PROJECT=storm-surge-487802

# Deploy metadata (optional)
APP_VERSION=
GIT_COMMIT=
GIT_BRANCH=
