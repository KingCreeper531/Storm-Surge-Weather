{
  "name": "storm-surge-weather",
  "version": "13.8.0",
  "description": "Storm Surge Weather — Electron desktop app with NEXRAD radar, AI assistant, Spotter Network",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.stormsurge.weather",
    "productName": "Storm Surge Weather",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "server.js",
      "public/**",
      "assets/**",
      "node_modules/**",
      "package.json"
    ]
  }
}
